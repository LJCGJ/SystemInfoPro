// ============================================================
//  SystemInfoPro - app.rc
//  Informacoes de versao do executavel (aparece nas Propriedades
//  do arquivo no Windows Explorer)
//
//  Para o icone aparecer no Windows Explorer e nos atalhos:
//   1. No app, use o menu Ajuda -> "Gerar arquivo de icone (app.ico)"
//      e salve "app.ico" nesta pasta.
//   2. Descomente a linha abaixo (remova as duas barras //) e recompile.
//  O ID numerico 1 garante que o Windows use este como icone do .exe.
// ============================================================
#include <windows.h>

// 1 ICON "app.ico"

VS_VERSION_INFO VERSIONINFO
FILEVERSION     2,0,0,0
PRODUCTVERSION  2,0,0,0
FILEFLAGSMASK   VS_FFI_FILEFLAGSMASK
FILEFLAGS       0
FILEOS          VOS__WINDOWS32
FILETYPE        VFT_APP
FILESUBTYPE     VFT2_UNKNOWN
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        BLOCK "041604B0"   // Portugues (Brasil), Unicode
        BEGIN
            VALUE "CompanyName",      "Projeto Open Source"
            VALUE "FileDescription",  "SystemInfoPro - Painel de Informacoes do Sistema"
            VALUE "FileVersion",      "2.0.0.0"
            VALUE "InternalName",     "SystemInfoPro"
            VALUE "LegalCopyright",   "Licenca MIT - Codigo Aberto e Gratuito"
            VALUE "OriginalFilename", "SystemInfoPro.exe"
            VALUE "ProductName",      "SystemInfoPro"
            VALUE "ProductVersion",   "2.0.0.0"
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x0416, 1200
    END
END
